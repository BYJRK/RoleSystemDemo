<UserControl x:Class="RoleSystemDemo.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RoleSystemDemo.ViewModels"
             xmlns:models="clr-namespace:RoleSystemDemo.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:AdminViewModel}"
             d:Width="500"
             d:Height="500"
             mc:Ignorable="d">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,16"
                   Text="管理员面板"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <TabControl Grid.Row="1">

            <TabItem Header="用户管理">
                <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Users}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UserAdminItemViewModel}">
                                <Border Margin="0,0,0,8"
                                        Padding="16,12"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 用户名 -->
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Username}"
                                                   FontWeight="Medium" />

                                        <!-- 角色下拉 -->
                                        <ComboBox Grid.Column="1"
                                                  MaxWidth="160"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding AllRoles}"
                                                  SelectedItem="{Binding SelectedRole}"
                                                  IsEnabled="{Binding CanModify}">
                                            <ComboBox.ToolTip>
                                                <ToolTip>
                                                    <TextBlock>
                                                        <Run Text="当前角色：" /><Run Text="{Binding SelectedRole}" />
                                                        <LineBreak />
                                                        <Run Text="（无法修改当前登录账号自身的角色）" />
                                                    </TextBlock>
                                                </ToolTip>
                                            </ComboBox.ToolTip>
                                        </ComboBox>

                                        <!-- 保存角色 -->
                                        <Button Grid.Column="2"
                                                Margin="10,0,8,0"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Content="保存角色"
                                                Command="{Binding SaveRoleCommand}"
                                                IsEnabled="{Binding CanModify}" />

                                        <!-- 删除用户 -->
                                        <Button Grid.Column="3"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Content="删除"
                                                Command="{Binding DeleteCommand}"
                                                IsEnabled="{Binding CanModify}"
                                                ToolTip="删除此用户（无法删除当前登录账号）" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="帖子管理">
                <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AllPosts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PostAdminItemViewModel}">
                                <Border Margin="0,0,0,8"
                                        Padding="16,12"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Title}"
                                                   FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Column="1"
                                                   Margin="8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <Run Text="by " /><Run Text="{Binding AuthorName, Mode=OneWay}" />
                                        </TextBlock>

                                        <Button Grid.Column="2"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Content="删除"
                                                Command="{Binding DeleteCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
