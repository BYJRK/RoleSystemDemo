<UserControl x:Class="RoleSystemDemo.Views.BlogDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RoleSystemDemo.ViewModels"
             xmlns:models="clr-namespace:RoleSystemDemo.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:BlogDetailViewModel}"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="800" Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 返回按钮 -->
            <Button Grid.Row="0"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Left"
                    Content="← 返回列表"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource HyperlinkButtonStyle}" />

            <!-- 文章标题 -->
            <TextBlock Grid.Row="1"
                       Margin="0,0,0,8"
                       Text="{Binding Title}"
                       Style="{StaticResource TitleTextBlockStyle}"
                       TextWrapping="Wrap" />

            <!-- 元信息 -->
            <TextBlock Grid.Row="2" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Run Text="作者：" /><Run Text="{Binding AuthorName, Mode=OneWay}" FontWeight="Medium" />
                <Run Text="  ·  " />
                <Run Text="{Binding PublishedAt, Mode=OneWay}" />
                <Run Text="{Binding UpdatedAt, Mode=OneWay}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </TextBlock>

            <Separator Grid.Row="3" Margin="0,12,0,16" />

            <!-- 正文 -->
            <TextBlock Grid.Row="4"
                       Margin="0,0,0,32"
                       Text="{Binding Content}"
                       TextWrapping="Wrap"
                       LineHeight="28" />

            <!--
                ═══════════════════════════════════════════════════════
                【模式三：动态内容】互动区域
                根据角色显示完全不同的内容
                ═══════════════════════════════════════════════════════
            -->
            <Border Grid.Row="5"
                    Padding="20,16"
                    CornerRadius="8"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <!-- Guest：警告色背景 -->
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InteractionRole}" Value="{x:Static models:UserRole.Admin}">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding InteractionRole}" Value="{x:Static models:UserRole.Guest}">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <TextBlock Margin="0,0,0,8"
                               Text="{Binding InteractionTitle}"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding InteractionHint}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               LineHeight="22" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
