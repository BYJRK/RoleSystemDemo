<UserControl x:Class="RoleSystemDemo.Views.BlogListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RoleSystemDemo.ViewModels"
             xmlns:services="clr-namespace:RoleSystemDemo.Services"
             d:DataContext="{d:DesignInstance vm:BlogListViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <TextBlock Grid.Row="0"
                   Text="博客列表"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,16"/>

        <!-- 新建帖子区域 -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 提示文字 — Guest 时显示，有权限时隐藏 -->
                <TextBlock Grid.Column="0"
                           Text="{Binding NewPostHint}"
                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewPostHint}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 占位（有权限时显示帖子数量） -->
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="共 "/><Run Text="{Binding Posts.Count, Mode=OneWay}"/><Run Text=" 篇博客"/>
                </TextBlock>

                <!-- 写博客按钮 — Guest 可见但置灰，悬停显示说明 -->
                <Button Grid.Column="2"
                        Content="✏️ 写博客"
                        Command="{Binding NewPostCommand}"
                        IsEnabled="{Binding NewPostEnabled}"
                        ToolTip="{Binding NewPostButtonTooltip}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="16,6"/>
            </Grid>
        </Border>

        <!-- 帖子列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Posts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BlogPostItemViewModel}">
                        <!-- 帖子卡片 -->
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="0,0,0,10"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 标题行 + 操作按钮 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="{Binding Title}"
                                            Command="{Binding ViewCommand}"
                                            Style="{StaticResource HyperlinkButtonStyle}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>

                                    <!-- 操作按钮组 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <!-- 编辑按钮 — 始终可见，权限不足时置灰 -->
                                        <Button Content="编辑"
                                                Command="{Binding EditCommand}"
                                                IsEnabled="{Binding CanEdit}"
                                                ToolTip="{Binding EditTooltip}"
                                                Padding="10,4"
                                                Margin="0,0,8,0"/>

                                        <!-- 删除按钮 — 始终可见，权限不足时置灰 -->
                                        <Button Content="删除"
                                                Command="{Binding DeleteCommand}"
                                                IsEnabled="{Binding CanDelete}"
                                                ToolTip="{Binding DeleteTooltip}"
                                                Padding="10,4"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 摘要 -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Summary}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,6"/>

                                <!-- 元信息 -->
                                <TextBlock Grid.Row="2"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="12">
                                    <Run Text="作者："/><Run Text="{Binding AuthorName, Mode=OneWay}"/>
                                    <Run Text="  "/>
                                    <Run Text="发布于 "/><Run Text="{Binding CreatedAt, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态提示 -->
        <TextBlock Grid.Row="2"
                   Text="暂无博客，快来写第一篇吧！"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   FontSize="16">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Posts.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
