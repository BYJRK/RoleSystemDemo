<Window x:Class="RoleSystemDemo.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RoleSystemDemo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="登录 — 角色权限博客系统"
        Width="450"
        d:DataContext="{d:DesignInstance vm:LoginViewModel}"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Grid>
        <Border Padding="40,32" VerticalAlignment="Center">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Margin="0,0,0,4"
                           HorizontalAlignment="Center"
                           Text="欢迎登录"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Margin="0,0,0,28"
                           HorizontalAlignment="Center"
                           Text="角色权限博客系统"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- 用户名 -->
                <TextBlock Margin="0,0,0,6" Text="用户名" FontWeight="Medium" />
                <TextBox Margin="0,0,0,14"
                         InputMethod.IsInputMethodEnabled="False"
                         ToolTip="测试账号：admin（admin123）/ alice（alice123）/ bob（bob123）"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <!-- 密码 -->
                <TextBlock Margin="0,0,0,6" Text="密码" FontWeight="Medium" />
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8" PasswordChanged="PasswordBox_PasswordChanged" />

                <!-- 错误提示 -->
                <TextBlock Margin="0,0,0,8"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 登录按钮 -->
                <Button Margin="0,8,0,0"
                        Padding="0,10"
                        HorizontalAlignment="Stretch"
                        Content="登 录"
                        IsDefault="True"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource AccentButtonStyle}" />

                <!-- 分隔线 -->
                <Grid Margin="0,16,0,12">
                    <Separator />
                    <TextBlock Text="或"
                               HorizontalAlignment="Center"
                               Padding="8,0"
                               Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12" />
                </Grid>

                <!-- 访客模式按钮 -->
                <Button Padding="0,8"
                        HorizontalAlignment="Stretch"
                        Content="👁 以访客身份浏览（只读）"
                        Command="{Binding EnterAsGuestCommand}"
                        ToolTip="访客可浏览全部博客，但无法发布或编辑内容" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
